# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Admin authentication (required)
# ADMIN_PIN: 6-8 character numeric PIN for admin console access (min entropy: 10^6)
ADMIN_PIN=your-strong-admin-pin-here
# ADMIN_SESSION_SECRET: 32+ character random secret for HMAC signing admin session tokens
ADMIN_SESSION_SECRET=your-32-character-random-secret-for-admin-sessions

# Cloudflare Turnstile CAPTCHA (optional - disables CAPTCHA on login/register if omitted)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your-turnstile-site-key-here
TURNSTILE_SECRET_KEY=your-turnstile-secret-key-here

# Stripe Payments (required for paid packages / subscription tiers)
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY: client-side publishable key (pk_live_... / pk_test_...)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-publishable-key-here
# STRIPE_SECRET_KEY: server-side secret key (sk_live_... / sk_test_...)
STRIPE_SECRET_KEY=sk_test_your-secret-key-here
# STRIPE_WEBHOOK_SECRET: signing secret for the /api/webhooks/stripe endpoint (whsec_...)
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-signing-secret-here

# Google Gemini API (optional - disables AI synthesis if omitted)
# Used for AI-powered assessment interpretation and synthesis
GEMINI_API_KEY=your-gemini-api-key-here

# Upstash Redis for rate limiting (optional - falls back to Supabase table if omitted)
UPSTASH_REDIS_REST_URL=https://your-region.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token-here

# Sentry Error Tracking & Performance Monitoring (optional - disables error reporting if omitted)
# Create a Sentry account at https://sentry.io, create a Next.js project, and copy the DSN here
NEXT_PUBLIC_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
SENTRY_AUTH_TOKEN=your-sentry-auth-token

# Logging Level (optional - defaults to 'info' in production, 'debug' in development)
LOG_LEVEL=info

# Site URL (required for canonical URLs and password reset links)
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# Native push notifications (optional; default off).
# Push requires a configured Firebase project (google-services.json on Android /
# APNs on iOS). Leaving this unset/false prevents the native app from calling
# PushNotifications.register() — which would otherwise crash on a device with no
# Firebase config. Set to true only after push is fully configured.
NEXT_PUBLIC_PUSH_ENABLED=false

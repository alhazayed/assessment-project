<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Base application theme. -->
    <style name="AppTheme" parent="Theme.AppCompat.Light.DarkActionBar">
        <!-- Customize your theme here. -->
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item>
    </style>

    <style name="AppTheme.NoActionBar" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="android:background">@null</item>
        <!-- Android 15 (targetSdk 35) enforces edge-to-edge, drawing the WebView
             behind the status and navigation bars. This app is designed with an
             opaque status bar (#12273C) and no CSS safe-area insets, so enforcement
             makes the web content render behind the bars and appear to not fit the
             screen. Opt out to keep the WebView within the system-bar insets.
             The attribute is API 35+; older devices ignore it. -->
        <item name="android:windowOptOutEdgeToEdgeEnforcement">true</item>
    </style>


    <style name="AppTheme.NoActionBarLaunch" parent="Theme.SplashScreen">
        <!-- Pre-Android-12 full-screen splash image -->
        <item name="android:background">@drawable/splash</item>
        <!-- Android 12+ system splash: branded brain icon on white -->
        <item name="windowSplashScreenBackground">@color/ic_launcher_background</item>
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher_foreground</item>
        <item name="postSplashScreenTheme">@style/AppTheme.NoActionBar</item>
        <!-- Keep the launch window consistent with the post-splash theme (see note above). -->
        <item name="android:windowOptOutEdgeToEdgeEnforcement">true</item>
    </style>
</resources>
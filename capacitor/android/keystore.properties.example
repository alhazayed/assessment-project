# Copy this file to `keystore.properties` (git-ignored) and fill in your
# Android upload keystore details to produce signed release bundles.
#
# Generate an upload keystore once with:
#   keytool -genkey -v -keystore vwelfare-upload.keystore \
#     -alias vwelfare -keyalg RSA -keysize 2048 -validity 10000
#
# storeFile is resolved relative to capacitor/android/.
storeFile=vwelfare-upload.keystore
storePassword=CHANGE_ME
keyAlias=vwelfare
keyPassword=CHANGE_ME
